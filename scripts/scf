#!/usr/bin/env python3
"""SPARK Framework — single-command onboarding launcher.

Uso (Linux/macOS):
    python scripts/scf [init]

Uso (Windows):
    py scripts/scf [init]
    python scripts/scf [init]
"""
from __future__ import annotations

import sys
from pathlib import Path

# Aggiunge la root del repository a sys.path in modo che spark.* sia importabile
# sia eseguendo direttamente questo script sia da una directory diversa.
_REPO_ROOT = Path(__file__).resolve().parent.parent
if str(_REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(_REPO_ROOT))

from spark.cli import main  # noqa: E402

if __name__ == "__main__":
    main()
